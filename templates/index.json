    "sd_why_us": {
      "type": "custom-liquid",
      "name": "t:names.custom_liquid",
      "settings": {
        "custom_liquid": "<style>\n  .sd-why, .sd-why * { box-sizing: border-box; }\n  .sd-why {\n    --sd-green: #1F6E4A; --sd-orange: #F5900F; --sd-dark: #0F2E20;\n    width: 100%; padding: 30px 14px 44px;\n    background: linear-gradient(180deg, #ffffff 0%, #f6faf8 55%, #eef8f2 100%);\n    font-family: Arial, Helvetica, sans-serif;\n  }\n  .sd-why__inner { max-width: 1180px; margin: 0 auto; }\n  .sd-why__head { text-align: center; margin-bottom: 22px; }\n  .sd-why__title { margin: 0; color: var(--sd-dark); font-family: Georgia, serif; font-size: 30px; font-weight: 900; letter-spacing: -.03em; }\n  .sd-why__subtitle { max-width: 440px; margin: 12px auto 0; color: rgba(15,46,32,.6); font-size: 13px; line-height: 1.55; font-weight: 600; }\n  .sd-why__grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; }\n  .sd-why-card { position: relative; overflow: hidden; min-height: 120px; padding: 14px 12px; border-radius: 20px; background: #fff; border: 1px solid rgba(15,46,32,.08); box-shadow: 0 10px 22px rgba(15,46,32,.04); }\n  .sd-why-card__icon { width: 34px; height: 34px; margin-bottom: 12px; border-radius: 12px; background: rgba(31,110,74,.1); color: var(--sd-green); display: inline-flex; align-items: center; justify-content: center; }\n  .sd-why-card__icon svg { width: 18px; height: 18px; }\n  .sd-why-card__icon path, .sd-why-card__icon circle { fill: none; stroke: currentColor; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }\n  .sd-why-card__title { margin: 0 0 5px; color: var(--sd-dark); font-size: 13px; font-weight: 900; }\n  .sd-why-card__text { margin: 0; color: rgba(15,46,32,.55); font-size: 10.5px; line-height: 1.4; font-weight: 600; }\n  .sd-why-card--hl { background: linear-gradient(145deg, var(--sd-green), var(--sd-dark)); border: none; }\n  .sd-why-card--hl .sd-why-card__icon { background: var(--sd-orange); color: #fff; }\n  .sd-why-card--hl .sd-why-card__title, .sd-why-card--hl .sd-why-card__text { color: #fff; }\n  .sd-why-card--hl .sd-why-card__text { color: rgba(255,255,255,.75); }\n\n  @media (min-width: 750px) {\n    .sd-why { padding: 48px 18px 62px; }\n    .sd-why__title { font-size: 46px; }\n    .sd-why__grid { grid-template-columns: repeat(3, 1fr); gap: 16px; }\n    .sd-why-card { min-height: 150px; padding: 18px; }\n    .sd-why-card__title { font-size: 16px; }\n    .sd-why-card__text { font-size: 12px; }\n  }\n</style>\n\n<section class=\"sd-why\">\n  <div class=\"sd-why__inner\">\n    <div class=\"sd-why__head\">\n      <h2 class=\"sd-why__title\">Pourquoi SouknDay ?</h2>\n      <p class=\"sd-why__subtitle\">Une expérience d'achat simple, rassurante, pensée pour le Maroc.</p>\n    </div>\n    <div class=\"sd-why__grid\">\n      <div class=\"sd-why-card\">\n        <div class=\"sd-why-card__icon\"><svg viewBox=\"0 0 24 24\"><rect x=\"3\" y=\"6\" width=\"18\" height=\"12\" rx=\"3\"></rect><path d=\"M3 10h18\"></path></svg></div>\n        <h3 class=\"sd-why-card__title\">Paiement à la livraison</h3>\n        <p class=\"sd-why-card__text\">Commandez tranquillement, payez à la réception.</p>\n      </div>\n      <div class=\"sd-why-card\">\n        <div class=\"sd-why-card__icon\"><svg viewBox=\"0 0 24 24\"><path d=\"M3 7h11v9H3z\"></path><path d=\"M14 10h4l3 3v3h-7z\"></path><circle cx=\"7\" cy=\"18\" r=\"1.8\"></circle><circle cx=\"18\" cy=\"18\" r=\"1.8\"></circle></svg></div>\n        <h3 class=\"sd-why-card__title\">Livraison rapide</h3>\n        <p class=\"sd-why-card__text\">Partout au Maroc, sous 24 à 72h.</p>\n      </div>\n      <div class=\"sd-why-card\">\n        <div class=\"sd-why-card__icon\"><svg viewBox=\"0 0 24 24\"><path d=\"M12 3l7 4v5c0 5-3.2 8-7 9-3.8-1-7-4-7-9V7z\"></path><path d=\"M8.5 12.2l2.2 2.2 4.8-5\"></path></svg></div>\n        <h3 class=\"sd-why-card__title\">Qualité vérifiée</h3>\n        <p class=\"sd-why-card__text\">Chaque produit est contrôlé avant l'envoi.</p>\n      </div>\n      <div class=\"sd-why-card\">\n        <div class=\"sd-why-card__icon\"><svg viewBox=\"0 0 24 24\"><path d=\"M4 7h11a4 4 0 0 1 0 8H8\"></path><path d=\"M8 11l-4 4 4 4\"></path></svg></div>\n        <h3 class=\"sd-why-card__title\">Échange facile</h3>\n        <p class=\"sd-why-card__text\">Un service client réactif en cas de souci.</p>\n      </div>\n      <div class=\"sd-why-card sd-why-card--hl\">\n        <div class=\"sd-why-card__icon\"><svg viewBox=\"0 0 24 24\"><path d=\"M20 12v8H4v-8\"></path><path d=\"M22 7H2v5h20z\"></path><path d=\"M12 7v13\"></path></svg></div>\n        <h3 class=\"sd-why-card__title\">Multi-catégories</h3>\n        <p class=\"sd-why-card__text\">Mode, maison, beauté, tech — tout au même endroit.</p>\n      </div>\n      <div class=\"sd-why-card\">\n        <div class=\"sd-why-card__icon\"><svg viewBox=\"0 0 24 24\"><path d=\"M4 14l5-5 4 4 7-7\"></path><path d=\"M20 6v5h-5\"></path></svg></div>\n        <h3 class=\"sd-why-card__title\">Prix accessible</h3>\n        <p class=\"sd-why-card__text\">Sélectionné pour le meilleur rapport qualité-prix.</p>\n      </div>\n    </div>\n  </div>\n</section>",
        "background_color": "",
        "section_width": "page-width",
        "padding-block-start": 0,
        "padding-block-end": 0
      }
    },
    "sd_reviews_faq_cta": {
      "type": "custom-liquid",
      "name": "t:names.custom_liquid",
      "settings": {
        "custom_liquid": "<!-- ============================================= -->\n<!-- BLOC 1 : TÉMOIGNAGES -->\n<!-- ============================================= -->\n<style>\n  .sd-rev, .sd-rev * { box-sizing: border-box; }\n  .sd-rev {\n    --sd-green: #1F6E4A; --sd-orange: #F5900F; --sd-dark: #0F2E20; --sd-gold: #F4C400;\n    width: 100%; padding: 44px 14px 48px;\n    background: linear-gradient(180deg, var(--sd-dark) 0%, #14261c 55%, var(--sd-dark) 100%);\n    font-family: Arial, Helvetica, sans-serif; color: #fff;\n  }\n  .sd-rev__inner { max-width: 1180px; margin: 0 auto; }\n  .sd-rev__head { text-align: center; margin-bottom: 20px; }\n  .sd-rev__title { margin: 0; font-family: Georgia, serif; font-size: 32px; font-weight: 900; letter-spacing: -.03em; }\n  .sd-rev__subtitle { max-width: 420px; margin: 13px auto 0; color: rgba(255,255,255,.65); font-size: 13px; line-height: 1.55; font-weight: 600; }\n  .sd-rev__grid { display: flex; gap: 12px; overflow-x: auto; scroll-snap-type: x mandatory; padding: 2px 4px 10px; scrollbar-width: none; }\n  .sd-rev__grid::-webkit-scrollbar { display: none; }\n  .sd-review-card { flex: 0 0 82%; scroll-snap-align: center; min-height: 170px; padding: 20px 16px; border-radius: 22px; background: #fff; color: var(--sd-dark); text-align: center; }\n  .sd-review-card__stars { color: var(--sd-gold); font-size: 18px; margin-bottom: 12px; }\n  .sd-review-card__text { margin: 0; font-size: 13px; line-height: 1.6; font-weight: 700; }\n  .sd-review-card__name { margin-top: 16px; font-size: 12px; font-weight: 800; font-style: italic; color: var(--sd-green); }\n  .sd-rev__trust { margin-top: 18px; padding: 13px 14px; border-radius: 20px; background: rgba(255,255,255,.06); display: grid; grid-template-columns: repeat(3,1fr); gap: 8px; }\n  .sd-rev__trust-item { text-align: center; color: rgba(255,255,255,.7); font-size: 10px; font-weight: 700; }\n  .sd-rev__trust-item strong { display: block; font-size: 14px; color: #fff; }\n  @media (min-width: 750px) {\n    .sd-rev { padding: 60px 18px 68px; }\n    .sd-rev__title { font-size: 48px; }\n    .sd-rev__grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 16px; overflow: visible; }\n    .sd-review-card { min-height: 200px; }\n  }\n</style>\n<section class=\"sd-rev\">\n  <div class=\"sd-rev__inner\">\n    <div class=\"sd-rev__head\">\n      <h2 class=\"sd-rev__title\">Ils nous font confiance</h2>\n      <p class=\"sd-rev__subtitle\">Vos avis comptent — voici ce que nos clients pensent de SouknDay.</p>\n    </div>\n    <div class=\"sd-rev__grid\">\n      <article class=\"sd-review-card\">\n        <div class=\"sd-review-card__stars\">★★★★★</div>\n        <p class=\"sd-review-card__text\">Commande reçue rapidement, produit conforme aux photos. Je recommande !</p>\n        <div class=\"sd-review-card__name\">Amine</div>\n      </article>\n      <article class=\"sd-review-card\">\n        <div class=\"sd-review-card__stars\">★★★★★</div>\n        <p class=\"sd-review-card__text\">Service client très réactif, livraison rapide sur Casablanca.</p>\n        <div class=\"sd-review-card__name\">Salma</div>\n      </article>\n      <article class=\"sd-review-card\">\n        <div class=\"sd-review-card__stars\">★★★★★</div>\n        <p class=\"sd-review-card__text\">Bon rapport qualité prix, j'ai déjà commandé 3 fois.</p>\n        <div class=\"sd-review-card__name\">Youssef</div>\n      </article>\n      <article class=\"sd-review-card\">\n        <div class=\"sd-review-card__stars\">★★★★★</div>\n        <p class=\"sd-review-card__text\">Le paiement à la livraison m'a rassuré pour ma première commande.</p>\n        <div class=\"sd-review-card__name\">Imane</div>\n      </article>\n    </div>\n    <div class=\"sd-rev__trust\">\n      <div class=\"sd-rev__trust-item\"><strong>4.8/5</strong>Note moyenne</div>\n      <div class=\"sd-rev__trust-item\"><strong>+5k</strong>Clients satisfaits</div>\n      <div class=\"sd-rev__trust-item\"><strong>24-72h</strong>Livraison</div>\n    </div>\n  </div>\n</section>\n\n\n<!-- ============================================= -->\n<!-- BLOC 2 : FAQ -->\n<!-- ============================================= -->\n<style>\n  .sd-faq, .sd-faq * { box-sizing: border-box; }\n  .sd-faq {\n    --sd-green: #1F6E4A; --sd-orange: #F5900F; --sd-dark: #0F2E20;\n    width: 100%; padding: 42px 14px 48px;\n    background: linear-gradient(180deg, #ffffff 0%, #f6faf8 52%, #eef8f2 100%);\n    font-family: Arial, Helvetica, sans-serif; color: var(--sd-dark);\n  }\n  .sd-faq__inner { max-width: 1180px; margin: 0 auto; }\n  .sd-faq__head { text-align: center; margin-bottom: 22px; }\n  .sd-faq__title { margin: 0; font-family: Georgia, serif; font-size: 34px; font-weight: 900; letter-spacing: -.03em; }\n  .sd-faq__subtitle { max-width: 480px; margin: 13px auto 0; color: rgba(15,46,32,.6); font-size: 13px; line-height: 1.55; font-weight: 600; }\n  .sd-faq__list { display: grid; gap: 11px; }\n  .sd-faq-item { overflow: hidden; border-radius: 20px; background: #fff; border: 1px solid rgba(15,46,32,.08); }\n  .sd-faq-item summary { list-style: none; cursor: pointer; padding: 16px; display: flex; align-items: center; justify-content: space-between; gap: 14px; font-size: 13.5px; font-weight: 900; }\n  .sd-faq-item summary::-webkit-details-marker { display: none; }\n  .sd-faq-item__plus { position: relative; width: 26px; height: 26px; flex: 0 0 auto; border-radius: 999px; background: rgba(31,110,74,.08); }\n  .sd-faq-item__plus::before, .sd-faq-item__plus::after { content: \"\"; position: absolute; left: 50%; top: 50%; width: 11px; height: 2px; background: var(--sd-green); transform: translate(-50%,-50%); }\n  .sd-faq-item__plus::after { transform: translate(-50%,-50%) rotate(90deg); transition: transform .18s ease; }\n  .sd-faq-item[open] .sd-faq-item__plus::after { transform: translate(-50%,-50%) rotate(0deg); }\n  .sd-faq-item__content { padding: 0 16px 17px; color: rgba(15,46,32,.55); font-size: 12px; line-height: 1.6; font-weight: 600; }\n  @media (min-width: 750px) {\n    .sd-faq { padding: 64px 18px 72px; }\n    .sd-faq__title { font-size: 52px; }\n    .sd-faq__list { max-width: 900px; margin: 0 auto; grid-template-columns: repeat(2,1fr); gap: 14px; }\n  }\n</style>\n<section class=\"sd-faq\">\n  <div class=\"sd-faq__inner\">\n    <div class=\"sd-faq__head\">\n      <h2 class=\"sd-faq__title\">FAQ</h2>\n      <p class=\"sd-faq__subtitle\">Les réponses à vos questions sur les commandes et la livraison.</p>\n    </div>\n    <div class=\"sd-faq__list\">\n      <details class=\"sd-faq-item\" open>\n        <summary>Quels sont les délais de livraison ? <span class=\"sd-faq-item__plus\"></span></summary>\n        <div class=\"sd-faq-item__content\">Entre 24h et 72h ouvrables selon votre ville.</div>\n      </details>\n      <details class=\"sd-faq-item\">\n        <summary>Le paiement à la livraison est-il disponible ? <span class=\"sd-faq-item__plus\"></span></summary>\n        <div class=\"sd-faq-item__content\">Oui, vous payez uniquement à la réception de votre commande.</div>\n      </details>\n      <details class=\"sd-faq-item\">\n        <summary>Comment fonctionne le retour produit ? <span class=\"sd-faq-item__plus\"></span></summary>\n        <div class=\"sd-faq-item__content\">Contactez notre service client sous 3 jours ouvrables avec photos à l'appui.</div>\n      </details>\n      <details class=\"sd-faq-item\">\n        <summary>Livrez-vous partout au Maroc ? <span class=\"sd-faq-item__plus\"></span></summary>\n        <div class=\"sd-faq-item__content\">Oui, dans toutes les grandes villes et la majorité des régions.</div>\n      </details>\n    </div>\n  </div>\n</section>\n<script>\ndocument.addEventListener(\"DOMContentLoaded\", function () {\n  document.querySelectorAll(\".sd-faq-item\").forEach(function (item) {\n    item.addEventListener(\"toggle\", function () {\n      if (item.open) {\n        document.querySelectorAll(\".sd-faq-item\").forEach(function (o) { if (o !== item) o.open = false; });\n      }\n    });\n  });\n});\n</script>\n\n\n<!-- ============================================= -->\n<!-- BLOC 3 : CTA FINAL -->\n<!-- ============================================= -->\n<style>\n  .sd-cta, .sd-cta * { box-sizing: border-box; }\n  .sd-cta {\n    --sd-green: #1F6E4A; --sd-orange: #F5900F; --sd-dark: #0F2E20;\n    width: 100%; padding: 46px 14px 54px;\n    background: linear-gradient(180deg, var(--sd-dark) 0%, #14261c 56%, var(--sd-dark) 100%);\n    font-family: Arial, Helvetica, sans-serif; color: #fff;\n  }\n  .sd-cta__inner { max-width: 820px; margin: 0 auto; }\n  .sd-cta__box { padding: 30px 18px 24px; border-radius: 30px; background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.14); text-align: center; }\n  .sd-cta__tag { width: fit-content; margin: 0 auto 14px; padding: 8px 13px; border-radius: 999px; background: rgba(245,144,15,.14); color: var(--sd-orange); font-size: 10.5px; font-weight: 950; letter-spacing: .06em; text-transform: uppercase; }\n  .sd-cta__title { margin: 0 auto; max-width: 600px; font-family: Georgia, serif; font-size: 34px; line-height: .98; font-weight: 900; letter-spacing: -.03em; }\n  .sd-cta__title span { color: var(--sd-orange); }\n  .sd-cta__text { max-width: 480px; margin: 16px auto 0; color: rgba(255,255,255,.72); font-size: 13.5px; line-height: 1.6; font-weight: 600; }\n  .sd-cta__btn { display: inline-flex; margin-top: 22px; min-height: 52px; padding: 0 26px; border-radius: 999px; background: var(--sd-orange); color: #fff !important; text-decoration: none !important; align-items: center; justify-content: center; font-size: 14px; font-weight: 950; transition: transform .2s ease; }\n  .sd-cta__btn:hover { transform: translateY(-2px); }\n  @media (min-width: 750px) {\n    .sd-cta { padding: 70px 18px 78px; }\n    .sd-cta__box { padding: 48px 44px 38px; border-radius: 38px; }\n    .sd-cta__title { font-size: 58px; }\n    .sd-cta__text { font-size: 16px; }\n  }\n</style>