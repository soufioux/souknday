{% doc %}
  @prompt
    commande ads
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-order-ads-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    margin: 0 auto;
  }

  .ai-order-ads-container-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .ai-order-ads-header-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-order-ads-title-{{ ai_gen_id }} {
    margin: 0 0 8px 0;
    color: {{ block.settings.title_color }};
    font-size: {{ block.settings.title_size }}px;
  }

  .ai-order-ads-subtitle-{{ ai_gen_id }} {
    margin: 0;
    color: {{ block.settings.subtitle_color }};
    font-size: {{ block.settings.subtitle_size }}px;
  }

  .ai-order-ads-content-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .ai-order-ads-image-wrapper-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.image_width }}px;
    height: {{ block.settings.image_height }}px;
    border-radius: {{ block.settings.image_border_radius }}px;
    overflow: hidden;
  }

  .ai-order-ads-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-order-ads-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-order-ads-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
  }

  .ai-order-ads-info-{{ ai_gen_id }} {
    flex-grow: 1;
  }

  .ai-order-ads-description-{{ ai_gen_id }} {
    margin: 0 0 16px 0;
    color: {{ block.settings.description_color }};
    font-size: {{ block.settings.description_size }}px;
    line-height: 1.5;
  }

  .ai-order-ads-features-{{ ai_gen_id }} {
    list-style: none;
    padding: 0;
    margin: 0 0 20px 0;
  }

  .ai-order-ads-feature-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 8px;
    color: {{ block.settings.features_color }};
    font-size: {{ block.settings.features_size }}px;
  }

  .ai-order-ads-feature-icon-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    color: {{ block.settings.icon_color }};
  }

  .ai-order-ads-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 12px 24px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    transition: background-color 0.3s ease;
  }

  .ai-order-ads-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
  }

  @media screen and (max-width: 749px) {
    .ai-order-ads-content-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-order-ads-image-wrapper-{{ ai_gen_id }} {
      width: 100%;
      max-width: {{ block.settings.image_width }}px;
    }
  }
{% endstyle %}

<ai-order-ads-{{ ai_gen_id }} class="ai-order-ads-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-order-ads-container-{{ ai_gen_id }}">
    {% if block.settings.title != blank or block.settings.subtitle != blank %}
      <div class="ai-order-ads-header-{{ ai_gen_id }}">
        {% if block.settings.title != blank %}
          <h2 class="ai-order-ads-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
        {% endif %}
        {% if block.settings.subtitle != blank %}
          <p class="ai-order-ads-subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-order-ads-content-{{ ai_gen_id }}">
      <div class="ai-order-ads-image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.image %}
          <img
            src="{{ block.settings.image | image_url: width: 600 }}"
            alt="{{ block.settings.image.alt | escape }}"
            class="ai-order-ads-image-{{ ai_gen_id }}"
            loading="lazy"
            width="{{ block.settings.image.width }}"
            height="{{ block.settings.image.height }}"
          >
        {% else %}
          <div class="ai-order-ads-image-placeholder-{{ ai_gen_id }}">
            {{ 'product-1' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>

      <div class="ai-order-ads-info-{{ ai_gen_id }}">
        {% if block.settings.description != blank %}
          <div class="ai-order-ads-description-{{ ai_gen_id }}">
            {{ block.settings.description }}
          </div>
        {% endif %}

        {% if block.settings.feature_1 != blank or block.settings.feature_2 != blank or block.settings.feature_3 != blank %}
          <ul class="ai-order-ads-features-{{ ai_gen_id }}">
            {% if block.settings.feature_1 != blank %}
              <li class="ai-order-ads-feature-{{ ai_gen_id }}">
                <svg class="ai-order-ads-feature-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
                <span>{{ block.settings.feature_1 }}</span>
              </li>
            {% endif %}
            {% if block.settings.feature_2 != blank %}
              <li class="ai-order-ads-feature-{{ ai_gen_id }}">
                <svg class="ai-order-ads-feature-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
                <span>{{ block.settings.feature_2 }}</span>
              </li>
            {% endif %}
            {% if block.settings.feature_3 != blank %}
              <li class="ai-order-ads-feature-{{ ai_gen_id }}">
                <svg class="ai-order-ads-feature-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
                <span>{{ block.settings.feature_3 }}</span>
              </li>
            {% endif %}
          </ul>
        {% endif %}

        {% if block.settings.button_text != blank %}
          <a href="{{ block.settings.button_link }}" class="ai-order-ads-button-{{ ai_gen_id }}">
            {{ block.settings.button_text }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</ai-order-ads-{{ ai_gen_id }}>

<script>
  (function() {
    class AiOrderAds{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('ai-order-ads-{{ ai_gen_id }}', AiOrderAds{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Order ads",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Commandez maintenant"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Offre spéciale limitée"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Profitez de notre offre exclusive et commandez dès aujourd'hui pour bénéficier de nos meilleurs prix.</p>"
    },
    {
      "type": "text",
      "id": "feature_1",
      "label": "Feature 1",
      "default": "Livraison rapide"
    },
    {
      "type": "text",
      "id": "feature_2",
      "label": "Feature 2",
      "default": "Garantie satisfait ou remboursé"
    },
    {
      "type": "text",
      "id": "feature_3",
      "label": "Feature 3",
      "default": "Support client 24/7"
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "range",
      "id": "image_width",
      "label": "Image width",
      "min": 100,
      "max": 400,
      "step": 20,
      "unit": "px",
      "default": 200
    },
    {
      "type": "range",
      "id": "image_height",
      "label": "Image height",
      "min": 100,
      "max": 400,
      "step": 20,
      "unit": "px",
      "default": 200
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "Image border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Commander maintenant"
    },
    {
