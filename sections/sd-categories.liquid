{% comment %}
  SouknDay — Categories grid (blocs répétables éditables : image, titre, lien par catégorie)
{% endcomment %}
<style>
  .sd-cats-{{ section.id }}, .sd-cats-{{ section.id }} * { box-sizing: border-box; }
  .sd-cats-{{ section.id }} {
    --sd-green: #1F6E4A; --sd-orange: #F5900F; --sd-dark: #0F2E20;
    width: 100%; padding: 24px 14px 46px;
    background: radial-gradient(circle at 85% 0%, rgba(31,110,74,.06), transparent 34%), #ffffff;
  }
  .sd-cats-{{ section.id }} .sd-cats__inner { max-width: 1180px; margin: 0 auto; }
  .sd-cats-{{ section.id }} .sd-cats__head { text-align: center; margin-bottom: 24px; }
  .sd-cats-{{ section.id }} .sd-cats__title { margin: 0; color: var(--sd-dark); font-family: Georgia, serif; font-size: 30px; font-weight: 900; letter-spacing: -.03em; }
  .sd-cats-{{ section.id }} .sd-cats__subtitle { max-width: 420px; margin: 12px auto 0; color: rgba(15,46,32,.6); font-size: 13px; line-height: 1.5; font-weight: 600; }
  .sd-cats-{{ section.id }} .sd-cats__grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; }
  .sd-cats-{{ section.id }} .sd-cat-card {
    display: flex; flex-direction: column; overflow: hidden; min-height: 200px; border-radius: 20px;
    background: #fff; border: 1px solid rgba(15,46,32,.08); text-decoration: none !important;
    box-shadow: 0 10px 24px rgba(15,46,32,.05); transition: transform .2s ease, box-shadow .2s ease;
  }
  .sd-cats-{{ section.id }} .sd-cat-card:hover { transform: translateY(-3px); box-shadow: 0 16px 32px rgba(15,46,32,.09); }
  .sd-cats-{{ section.id }} .sd-cat-card__media { width: 100%; height: 130px; background: linear-gradient(180deg,#fff 0%,#f0f7f3 100%); overflow: hidden; }
  .sd-cats-{{ section.id }} .sd-cat-card__media img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .sd-cats-{{ section.id }} .sd-cat-card__placeholder { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, rgba(31,110,74,.12), rgba(245,144,15,.12)); color: var(--sd-green); font-size: 26px; font-weight: 900; }
  .sd-cats-{{ section.id }} .sd-cat-card__body { flex: 1; padding: 12px; display: flex; flex-direction: column; justify-content: space-between; gap: 10px; }
  .sd-cats-{{ section.id }} .sd-cat-card__name { margin: 0; color: var(--sd-dark); font-size: 14px; font-weight: 900; }
  .sd-cats-{{ section.id }} .sd-cat-card__cta { display: inline-flex; align-items: center; gap: 6px; color: var(--sd-green); font-size: 11px; font-weight: 950; }

  @media (min-width: 750px) {
    .sd-cats-{{ section.id }} { padding: 40px 18px 60px; }
    .sd-cats-{{ section.id }} .sd-cats__title { font-size: 46px; }
    .sd-cats-{{ section.id }} .sd-cats__grid { grid-template-columns: repeat(4, 1fr); gap: 16px; }
    .sd-cats-{{ section.id }} .sd-cat-card { min-height: 240px; }
    .sd-cats-{{ section.id }} .sd-cat-card__media { height: 160px; }
  }
</style>

<section class="sd-cats-{{ section.id }}">
  <div class="sd-cats__inner">
    <div class="sd-cats__head">
      <h2 class="sd-cats__title">{{ section.settings.heading | default: 'Nos catégories' }}</h2>
      {%- if section.settings.subtitle != blank -%}
        <p class="sd-cats__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>
    <div class="sd-cats__grid">
      {%- for block in section.blocks -%}
        {%- assign target_url = '#' -%}
        {%- if block.settings.collection != blank -%}
          {%- assign target_url = block.settings.collection.url -%}
        {%- elsif block.settings.link != blank -%}
          {%- assign target_url = block.settings.link -%}
        {%- endif -%}
        <a href="{{ target_url }}" class="sd-cat-card" {{ block.shopify_attributes }}>
          <div class="sd-cat-card__media">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 600 | image_tag:
                  loading: 'lazy',
                  widths: '300,450,600',
                  sizes: '(min-width: 750px) 280px, 45vw',
                  alt: block.settings.title
              }}
            {%- elsif block.settings.collection != blank and block.settings.collection.featured_image != blank -%}
              {{ block.settings.collection.featured_image | image_url: width: 600 | image_tag:
                  loading: 'lazy',
                  widths: '300,450,600',
                  sizes: '(min-width: 750px) 280px, 45vw',
                  alt: block.settings.title
              }}
            {%- else -%}
              <div class="sd-cat-card__placeholder">{{ block.settings.title | slice: 0 }}</div>
            {%- endif -%}
          </div>
          <div class="sd-cat-card__body">
            <h3 class="sd-cat-card__name">{{ block.settings.title }}</h3>
            <div class="sd-cat-card__cta">Découvrir →</div>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "SouknDay – Catégories",
  "settings": [
    { "type": "text", "id": "heading", "label": "Titre", "default": "Nos catégories" },
    { "type": "textarea", "id": "subtitle", "label": "Sous-titre", "default": "Explore toutes nos sélections, du quotidien aux coups de cœur." }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Catégorie",
      "settings": [
        { "type": "text", "id": "title", "label": "Nom", "default": "Mode" },
        { "type": "collection", "id": "collection", "label": "Collection liée (recommandé)" },
        { "type": "image_picker", "id": "image", "label": "Image (remplace l'image de la collection si définie)" },
        { "type": "url", "id": "link", "label": "Lien manuel (si pas de collection)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "SouknDay – Catégories",
      "blocks": [
        { "type": "category", "settings": { "title": "Mode" } },
        { "type": "category", "settings": { "title": "Maison & déco" } },
        { "type": "category", "settings": { "title": "Beauté" } },
        { "type": "category", "settings": { "title": "Tech & accessoires" } }
      ]
    }
  ]
}
{% endschema %}
